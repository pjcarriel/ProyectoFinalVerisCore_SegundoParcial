@model IEnumerable<MoldeMVC_Core.Models.Especialidade>

@{
    ViewData["Title"] = "Listado de Especialidades";
    var total = Model.Count();

    string DiasCompletos(string dias)
    {
        if (string.IsNullOrWhiteSpace(dias)) return "—";
        var mapa = new Dictionary<char, string>
        {
            {'L', "Lunes"}, {'M', "Martes"}, {'X', "Miércoles"},
            {'J', "Jueves"}, {'V', "Viernes"}
        };
        var nombres = dias.ToUpper()
            .Where(c => mapa.ContainsKey(c))
            .Select(c => mapa[c]);
        return string.Join(", ", nombres);
    }
}

<div class="veris-table-card">
    <div class="veris-table-header">
        <h1>Especialidades</h1>
        <span class="veris-badge-count">@total registro@(total != 1 ? "s" : "")</span>
    </div>
    <div class="veris-table-toolbar">
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Nueva Especialidad</a>
    </div>
    <div class="veris-table-wrapper">
        <table class="table veris-table">
            <thead>
                <tr>
                    <th>Descripción</th>
                    <th>Días Disponibles</th>
                    <th>Hora Inicio</th>
                    <th>Hora Fin</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Descripcion</strong></td>
                        <td>
                            <span class="veris-badge-tipo">@DiasCompletos(item.Dias)</span>
                        </td>
                        <td><span class="veris-hora">@item.FranjaHi.ToString("HH:mm")</span></td>
                        <td><span class="veris-hora">@item.FranjaHf.ToString("HH:mm")</span></td>
                        <td>
                            <div class="veris-actions">
                                <a asp-action="Edit" asp-route-id="@item.IdEspecialidad" class="veris-btn-edit">&#9998; Editar</a>
                                <a asp-action="Details" asp-route-id="@item.IdEspecialidad" class="veris-btn-details">&#128269; Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.IdEspecialidad" class="veris-btn-delete">&#10005; Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="veris-table-footer">
        Total: @total especialidad@(total != 1 ? "es" : "") registrada@(total != 1 ? "s" : "")
    </div>
</div>
