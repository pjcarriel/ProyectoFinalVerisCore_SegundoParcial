@model MoldeMVC_Core.Models.Especialidades

@{
    ViewData["Title"] = "Detalles de Especialidad";

    string DiasCompletos(string dias)
    {
        if (string.IsNullOrWhiteSpace(dias)) return "—";
        var mapa = new Dictionary<char, string>
        {
            {'L', "Lunes"}, {'M', "Martes"}, {'X', "Miércoles"},
            {'J', "Jueves"}, {'V', "Viernes"}
        };
        return string.Join(", ", dias.ToUpper().Where(c => mapa.ContainsKey(c)).Select(c => mapa[c]));
    }
}

<div class="veris-detail-card">
    <div class="veris-detail-header">
        <div class="veris-form-icon">&#9733;</div>
        <h1>Detalles de Especialidad</h1>
    </div>

    <div class="veris-detail-body">
        <div class="veris-detail-row">
            <span class="veris-detail-label">Descripción</span>
            <span class="veris-detail-value">@Model.Descripcion</span>
        </div>
        <div class="veris-detail-row">
            <span class="veris-detail-label">Días disponibles</span>
            <span class="veris-detail-value">
                <span class="veris-badge-tipo">@DiasCompletos(Model.Dias)</span>
            </span>
        </div>
        <div class="veris-detail-row">
            <span class="veris-detail-label">Hora de inicio</span>
            <span class="veris-detail-value">
                <span class="veris-hora">@Model.FranjaHi.ToString("HH:mm")</span>
            </span>
        </div>
        <div class="veris-detail-row">
            <span class="veris-detail-label">Hora de fin</span>
            <span class="veris-detail-value">
                <span class="veris-hora">@Model.FranjaHf.ToString("HH:mm")</span>
            </span>
        </div>
    </div>

    <div class="veris-detail-footer">
        <a asp-action="Index" class="veris-btn-back">&#8592; Volver</a>
    </div>
</div>
