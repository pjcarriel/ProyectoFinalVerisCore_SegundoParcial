@model MoldeMVC_Core.Models.Medicamentos

@{
    ViewData["Title"] = "Detalles de Medicamento";
}

<div class="veris-detail-card">
    <div class="veris-detail-header">
        <div class="veris-form-icon">&#10010;</div>
        <h1>Detalles del Medicamento</h1>
    </div>

    <div class="veris-detail-body">
        <div class="veris-detail-row">
            <span class="veris-detail-label">Nombre</span>
            <span class="veris-detail-value">@Model.Nombre</span>
        </div>
        <div class="veris-detail-row">
            <span class="veris-detail-label">Tipo / Categoría</span>
            <span class="veris-detail-value">
                <span class="veris-badge-tipo">@Model.Tipo</span>
            </span>
        </div>
    </div>

    <div class="veris-detail-footer">
        <a asp-action="Index" class="veris-btn-back">&#8592; Volver</a>
    </div>
</div>
