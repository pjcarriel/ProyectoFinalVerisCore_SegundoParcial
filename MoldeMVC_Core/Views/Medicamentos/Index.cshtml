@model IEnumerable<MoldeMVC_Core.Models.Medicamento>

@{
    ViewData["Title"] = "Listado de Medicamentos";
    var total = Model.Count();
}

<div class="veris-table-card">
    <div class="veris-table-header">
        <h1>Medicamentos</h1>
        <span class="veris-badge-count">@total registro@(total != 1 ? "s" : "")</span>
    </div>
    <div class="veris-table-toolbar">
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Nuevo Medicamento</a>
    </div>
    <div class="veris-table-wrapper">
        <table class="table veris-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Nombre</strong></td>
                        <td><span class="veris-badge-tipo">@item.Tipo</span></td>
                        <td>
                            <div class="veris-actions">
                                <a asp-action="Edit" asp-route-id="@item.IdMedicamento" class="veris-btn-edit">&#9998; Editar</a>
                                <a asp-action="Details" asp-route-id="@item.IdMedicamento" class="veris-btn-details">&#128269; Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.IdMedicamento" class="veris-btn-delete">&#10005; Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="veris-table-footer">
        Total: @total medicamento@(total != 1 ? "s" : "") registrado@(total != 1 ? "s" : "")
    </div>
</div>
