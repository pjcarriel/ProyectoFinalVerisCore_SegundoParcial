<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VERIS</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MoldeMVC_Core.styles.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm fixed-top shadow-sm"
         style="background:white; border-top:6px solid #35283a;">
        <div class="container-fluid px-5">

            <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="~/Imagenes/Logo-Veris.png" alt="VERIS" style="height:62px; width:auto;" />
            </a>

            <button type="button" class="navbar-toggler"
                    data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1 align-items-center justify-content-center ms-5">

                    @if (User.Identity?.IsAuthenticated != true)
                    {
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Medicos" asp-action="Index">Módulo Médicos</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Pacientes" asp-action="Index">Módulo Pacientes</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Especialidades" asp-action="Index">Módulo Administrador</a>
                        </li>
                    }
                    @if (User.IsInRole("SuperAdmin"))
                    {
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Rol" asp-action="Index">Roles</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Medicos" asp-action="Index">Médicos</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Pacientes" asp-action="Index">Pacientes</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Especialidades" asp-action="Index">Especialidades</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Medicamentos" asp-action="Index">Medicamentos</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Consultas" asp-action="Index">Consultas</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Recetas" asp-action="Index">Recetas</a>
                        </li>
                    }
                    @if (User.IsInRole("Administrador"))
                    {
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Medicos" asp-action="Index">Médicos</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Pacientes" asp-action="Index">Pacientes</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Especialidades" asp-action="Index">Especialidades</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Medicamentos" asp-action="Index">Medicamentos</a>
                        </li>
                    }
                    @if (User.IsInRole("Medico"))
                    {
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Medicos" asp-action="Index">Mi Perfil</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Consultas" asp-action="Index">Consultas</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Recetas" asp-action="Index">Recetas</a>
                        </li>
                    }
                    @if (User.IsInRole("Paciente"))
                    {
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Pacientes" asp-action="Index">Mi Perfil</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Consultas" asp-action="Index">Mis Consultas</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Recetas" asp-action="Index">Mis Recetas</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="AgendarConsulta" asp-action="Index">Agendar Cita</a>
                        </li>
                    }

                </ul>

                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <div style="padding-top:105px;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="text-white mt-5" style="background:#142946; border-top:8px solid #2f6df6; font-size:0.82rem;">
        <div class="container-fluid px-4 py-5">
            <div class="row gy-4 align-items-start">

                <div class="col-md-3">
                    <h6 class="fw-bold mb-3">Sobre nosotros</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1">Preguntas frecuentes</li>
                        <li class="mb-1">Deberes y derechos del paciente</li>
                        <li class="mb-1">Términos y condiciones</li>
                        <li class="mb-1">Política de seguridad</li>
                        <li class="mb-1">Política de cookies</li>
                        <li class="mb-1">Trabaja con nosotros</li>
                        <li class="mb-1">Ubicaciones</li>
                    </ul>
                    <h6 class="fw-bold mt-3 mb-2">Agenda tu cita médica</h6>
                    <p class="mb-1">Agenda tu cita médica: 600 9 600</p>
                    <p class="mb-1">Cuéntanos tu experiencia</p>
                    <p class="mb-0">Portal para prestadores</p>
                </div>

                <div class="col-md-3">
                    <h6 class="fw-bold mb-2">Matriz Guayaquil</h6>
                    <p class="mb-1">Av. Juan Tanca Marengo y Av. Agustín Freire<br />Ycaza Esq. Edificio Veris</p>
                    <p class="mb-3">Teléfono oficinas: 603 2 000</p>
                    <h6 class="fw-bold mb-2">Oficinas Quito</h6>
                    <p class="mb-1">Av. Eloy Alfaro N33 - 400 y Fernando Ayarza</p>
                    <p class="mb-3">Teléfono oficinas: 603 2 000</p>
                    <h6 class="fw-bold mb-2">Oficinas Cuenca</h6>
                    <p class="mb-1">Av. Solano y Remigio Crespo, Centro Médico Veris</p>
                    <p class="mb-0">Teléfono oficinas: 603 2 000</p>
                </div>

                <div class="col-md-3">
                    <p class="fw-bold mb-2" style="font-size:0.9rem;">
                        Encuentra citas, tratamientos,<br />
                        recetas y tus resultados
                    </p>
                    <p class="fw-bold mb-3" style="color:#76a7ff; font-size:1.25rem;">en un solo lugar.</p>
                    <div class="d-flex gap-3 flex-wrap">
                        <div class="bg-dark rounded-3 px-3 py-2">App Store</div>
                        <div class="bg-dark rounded-3 px-3 py-2">Google Play</div>
                    </div>
                </div>

                <div class="col-md-3 text-center">
                    <img src="~/Imagenes/MedicosVeris.jpeg" alt="VERIS"
                         class="img-fluid shadow"
                         style="max-height:250px; width:100%; object-fit:cover; border-radius:24px; border:4px solid rgba(255,255,255,0.25);" />
                </div>

            </div>

            <hr class="border-light opacity-25 my-4" />

            <div class="text-center small opacity-75">
                &copy; @DateTime.Now.Year VERIS
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
