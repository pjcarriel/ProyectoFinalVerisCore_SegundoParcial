@model MoldeMVC_Core.Models.Paciente

@{
    ViewData["Title"] = "Editar Paciente";
    var fotos = ViewBag.Fotos as List<string> ?? new List<string>();
}

<div class="veris-form-card veris-form-card-wide">
    <div class="veris-form-header">
        <div class="veris-form-icon">&#9998;</div>
        <h1>Editar Paciente</h1>
    </div>
    <form asp-action="Edit" method="post">
        <div class="veris-form-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="IdPaciente" />

            <div class="veris-form-grid-2">

                <div class="veris-form-group veris-col-full">
                    <label asp-for="IdUsuario" class="veris-form-label">Usuario</label>
                    <select asp-for="IdUsuario" asp-items="ViewBag.Usuarios" class="veris-form-control">
                        <option value="">-- Seleccione un usuario --</option>
                    </select>
                    <span asp-validation-for="IdUsuario" class="veris-form-error"></span>
                </div>

                <div class="veris-form-group veris-col-full">
                    <label asp-for="Nombre" class="veris-form-label">Nombre completo</label>
                    <input asp-for="Nombre" class="veris-form-control" />
                    <span asp-validation-for="Nombre" class="veris-form-error"></span>
                </div>

                <div class="veris-form-group">
                    <label asp-for="Cedula" class="veris-form-label">Cédula</label>
                    <input asp-for="Cedula" type="text" maxlength="10" pattern="[0-9]{1,10}"
                           class="veris-form-control"
                           oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
                    <span asp-validation-for="Cedula" class="veris-form-error"></span>
                </div>

                <div class="veris-form-group">
                    <label asp-for="Edad" class="veris-form-label">Edad (años)</label>
                    <input asp-for="Edad" type="number" min="0" class="veris-form-control" />
                    <span asp-validation-for="Edad" class="veris-form-error"></span>
                </div>

                <div class="veris-form-group">
                    <label asp-for="Genero" class="veris-form-label">Género</label>
                    <select asp-for="Genero" class="veris-form-control">
                        <option value="">-- Seleccione --</option>
                        <option value="Masculino">Masculino</option>
                        <option value="Femenino">Femenino</option>
                        <option value="Otro">Otro</option>
                    </select>
                    <span asp-validation-for="Genero" class="veris-form-error"></span>
                </div>

                <div class="veris-form-group">
                    <label asp-for="Estatura" class="veris-form-label">Estatura (cm)</label>
                    <input asp-for="Estatura" type="number" min="0" class="veris-form-control" />
                    <span asp-validation-for="Estatura" class="veris-form-error"></span>
                </div>

                <div class="veris-form-group">
                    <label asp-for="Peso" class="veris-form-label">Peso (kg)</label>
                    <input asp-for="Peso" type="number" min="0" class="veris-form-control" />
                    <span asp-validation-for="Peso" class="veris-form-error"></span>
                </div>

                <div class="veris-form-group veris-col-full">
                    <label asp-for="Foto" class="veris-form-label">Foto</label>
                    <select asp-for="Foto" class="veris-form-control" id="fotoSelectPaciente"
                            onchange="previewFotoPacienteEdit()">
                        <option value="">-- Sin foto --</option>
                        @foreach (var f in fotos)
                        {
                            <option value="@f">@f</option>
                        }
                    </select>
                    <span asp-validation-for="Foto" class="veris-form-error"></span>
                    <div id="fotoPreviewPaciente" class="veris-foto-preview mt-2" style="display:none;">
                        <img id="fotoImgPaciente" src="" alt="Vista previa" class="veris-foto-circle" />
                        <span class="veris-foto-preview-label" id="fotoLabelPaciente"></span>
                    </div>
                </div>

            </div>
        </div>
        <div class="veris-form-footer">
            <button type="submit" class="veris-btn-submit">&#10003; Guardar Cambios</button>
            <a asp-action="Index" class="veris-btn-back">&#8592; Volver</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function previewFotoPacienteEdit() {
            var sel = document.getElementById('fotoSelectPaciente');
            var preview = document.getElementById('fotoPreviewPaciente');
            var img = document.getElementById('fotoImgPaciente');
            var label = document.getElementById('fotoLabelPaciente');
            if (sel.value) {
                img.src = '/Usuarios/' + sel.value;
                label.textContent = sel.value;
                preview.style.display = 'flex';
            } else {
                preview.style.display = 'none';
            }
        }
        window.addEventListener('DOMContentLoaded', previewFotoPacienteEdit);
    </script>
}
