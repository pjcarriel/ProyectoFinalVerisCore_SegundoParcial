@model MoldeMVC_Core.Models.Pacientes

@{
    ViewData["Title"] = "Eliminar Paciente";
}

<h1>Eliminar Paciente</h1>
<h3>¿Está seguro que desea eliminar este registro?</h3>

<div>
    <h4>Paciente</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>

        <dt class="col-sm-3">Cédula</dt>
        <dd class="col-sm-9">@Model.Cedula</dd>

        <dt class="col-sm-3">Edad</dt>
        <dd class="col-sm-9">@Model.Edad</dd>

        <dt class="col-sm-3">Género</dt>
        <dd class="col-sm-9">@Model.Genero</dd>

        <dt class="col-sm-3">Estatura</dt>
        <dd class="col-sm-9">@Model.Estatura cm</dd>

        <dt class="col-sm-3">Peso</dt>
        <dd class="col-sm-9">@Model.Peso kg</dd>

        <dt class="col-sm-3">Foto</dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(Model.Foto))
            {
                <img src="~/usuarios/@Model.Foto" alt="Foto del paciente" width="150" height="150" style="object-fit: cover;" />
            }
            else
            {
                <span>Sin foto</span>
            }
        </dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.IdStr" method="post">
        <input type="submit" value="Eliminar" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </form>
</div>
