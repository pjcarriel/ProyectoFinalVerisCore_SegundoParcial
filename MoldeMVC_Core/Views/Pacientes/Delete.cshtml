@model MoldeMVC_Core.Models.Pacientes

@{
    ViewData["Title"] = "Eliminar Paciente";
}

<h1>Eliminar Paciente</h1>

<h3>¿Está seguro que desea eliminar este registro?</h3>

<div>
    <h4>Pacientes</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">
            ID
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model._id)
        </dd>

        <dt class="col-sm-3">
            Nombre
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.nombre)
        </dd>

        <dt class="col-sm-3">
            Cédula
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.cedula)
        </dd>

        <dt class="col-sm-3">
            Edad
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.edad)
        </dd>

        <dt class="col-sm-3">
            Género
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.genero)
        </dd>

        <dt class="col-sm-3">
            Estatura
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.estatura)
        </dd>

        <dt class="col-sm-3">
            Peso
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.peso)
        </dd>

        <dt class="col-sm-3">
            Foto
        </dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(Model.foto))
            {
                <img src="~/usuarios/@Model.foto"
                     alt="Foto del paciente"
                     width="150"
                     height="150"
                     style="object-fit: cover;" />
            }
            else
            {
                <span>Sin foto</span>
            }
        </dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="_id" />

        <input type="submit" value="Eliminar" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </form>
</div>