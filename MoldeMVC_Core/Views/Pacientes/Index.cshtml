@model IEnumerable<MoldeMVC_Core.Models.Pacientes>

@{
    ViewData["Title"] = "Listado de Pacientes";
    var total = Model.Count();
}

<div class="veris-table-card">
    <div class="veris-table-header">
        <h1>Pacientes</h1>
        <span class="veris-badge-count">@total registro@(total != 1 ? "s" : "")</span>
    </div>
    <div class="veris-table-toolbar">
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Nuevo Paciente</a>
    </div>
    <div class="veris-table-wrapper">
        <table class="table veris-table">
            <thead>
                <tr>
                    <th>Foto</th>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Edad</th>
                    <th>Género</th>
                    <th>Estatura</th>
                    <th>Peso</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.foto))
                            {
                                <img src="~/usuarios/@item.foto" alt="Foto del paciente" class="veris-foto-circle" />
                            }
                            else
                            {
                                <span class="veris-sin-foto">Sin<br />foto</span>
                            }
                        </td>
                        <td><strong>@Html.DisplayFor(modelItem => item.nombre)</strong></td>
                        <td>@Html.DisplayFor(modelItem => item.cedula)</td>
                        <td>@Html.DisplayFor(modelItem => item.edad) años</td>
                        <td>
                            <span class="veris-badge-tipo">@Html.DisplayFor(modelItem => item.genero)</span>
                        </td>
                        <td><span class="veris-hora">@Html.DisplayFor(modelItem => item.estatura) cm</span></td>
                        <td><span class="veris-hora">@Html.DisplayFor(modelItem => item.peso) kg</span></td>
                        <td>
                            <div class="veris-actions">
                                <a asp-action="Edit" asp-route-id="@item._id" class="veris-btn-edit">&#9998; Editar</a>
                                <a asp-action="Details" asp-route-id="@item._id" class="veris-btn-details">&#128269; Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item._id" class="veris-btn-delete">&#10005; Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="veris-table-footer">
        Total: @total paciente@(total != 1 ? "s" : "") registrado@(total != 1 ? "s" : "")
    </div>
</div>
