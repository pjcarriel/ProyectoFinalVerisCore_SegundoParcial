@model IEnumerable<MoldeMVC_Core.Models.Pacientes>

@{
    ViewData["Title"] = "Listado de Pacientes";
    var total = Model.Count();
}

<div class="veris-table-card">
    <div class="veris-table-header">
        <h1>Pacientes</h1>
        <span class="veris-badge-count">@total registro@(total != 1 ? "s" : "")</span>
    </div>
    @if (!User.IsInRole("Paciente"))
    {
        <div class="veris-table-toolbar">
            <a asp-action="Create" class="btn btn-primary btn-sm">+ Nuevo Paciente</a>
        </div>
    }
    <div class="veris-table-wrapper">
        <table class="table veris-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Edad</th>
                    <th>Género</th>
                    <th>Estatura</th>
                    <th>Peso</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Nombre</strong></td>
                        <td>@item.Cedula</td>
                        <td>@item.Edad años</td>
                        <td><span class="veris-badge-tipo">@item.Genero</span></td>
                        <td><span class="veris-hora">@item.Estatura cm</span></td>
                        <td><span class="veris-hora">@item.Peso kg</span></td>
                        <td>
                            <div class="veris-actions">
                                @if (!User.IsInRole("Paciente"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.IdStr" class="veris-btn-edit">&#9998; Editar</a>
                                }
                                <a asp-action="Details" asp-route-id="@item.IdStr" class="veris-btn-details">&#128269; Detalles</a>
                                @if (!User.IsInRole("Paciente"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.IdStr" class="veris-btn-delete">&#10005; Eliminar</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="veris-table-footer">
        Total: @total paciente@(total != 1 ? "s" : "") registrado@(total != 1 ? "s" : "")
    </div>
</div>
