@model IEnumerable<MoldeMVC_Core.Models.Consultas>

@{
    ViewData["Title"] = "Listado de Consultas";
    var total = Model.Count();
}

<div class="veris-table-card">
    <div class="veris-table-header">
        <h1>Consultas</h1>
        <span class="veris-badge-count">@total registro@(total != 1 ? "s" : "")</span>
    </div>
    <div class="veris-table-toolbar">
        <a asp-controller="AgendarConsulta" asp-action="Index" class="btn btn-primary btn-sm">+ Nueva Consulta</a>
    </div>
    <div class="veris-table-wrapper">
        <table class="table veris-table">
            <thead>
                <tr>
                    <th>Médico</th>
                    <th>Paciente</th>
                    <th>Fecha</th>
                    <th>Hora Inicio</th>
                    <th>Hora Fin</th>
                    <th>Diagnóstico</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>
                                @(ViewBag.MedicosDict != null && ViewBag.MedicosDict.ContainsKey(item.medicoId)
                                    ? ViewBag.MedicosDict[item.medicoId]
                                    : item.medicoId)
                            </strong>
                        </td>
                        <td>
                            @(ViewBag.PacientesDict != null && ViewBag.PacientesDict.ContainsKey(item.pacienteId)
                                ? ViewBag.PacientesDict[item.pacienteId]
                                : item.pacienteId)
                        </td>
                        <td>
                            <span class="veris-badge-tipo">@item.fechaConsulta.ToString("dd/MM/yyyy")</span>
                        </td>
                        <td><span class="veris-hora">@(item.hi?.Length > 5 ? item.hi.Substring(0, 5) : item.hi)</span></td>
                        <td><span class="veris-hora">@(item.hf?.Length > 5 ? item.hf.Substring(0, 5) : item.hf)</span></td>
                        <td>
                            <span class="veris-badge-diagnostico" title="@item.diagnostico">
                                @Html.DisplayFor(modelItem => item.diagnostico)
                            </span>
                        </td>
                        <td>
                            <div class="veris-actions">
                                @if (string.IsNullOrWhiteSpace(item.diagnostico) || item.diagnostico.Trim().ToLower() == "pendiente")
                                {
                                    <a asp-action="Atender" asp-route-id="@item._id" class="veris-btn-atender">&#128203; Atender</a>
                                }
                                <a asp-action="Edit" asp-route-id="@item._id" class="veris-btn-edit">&#9998; Editar</a>
                                <a asp-action="Details" asp-route-id="@item._id" class="veris-btn-details">&#128269; Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item._id" class="veris-btn-delete">&#10005; Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="veris-table-footer">
        Total: @total consulta@(total != 1 ? "s" : "") registrada@(total != 1 ? "s" : "")
    </div>
</div>
