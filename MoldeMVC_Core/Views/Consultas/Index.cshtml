@model IEnumerable<MoldeMVC_Core.Models.Consultas>

@{
    ViewData["Title"] = "Listado de Consultas";
    var total = Model.Count();
}

<div class="veris-table-card">
    <div class="veris-table-header">
        <h1>Consultas</h1>
        <span class="veris-badge-count">@total registro@(total != 1 ? "s" : "")</span>
    </div>
    @if (!User.IsInRole("Paciente") && !User.IsInRole("Medico"))
    {
        <div class="veris-table-toolbar">
            <a asp-controller="AgendarConsulta" asp-action="Index" class="btn btn-primary btn-sm">+ Nueva Consulta</a>
        </div>
    }
    <div class="veris-table-wrapper">
        <table class="table veris-table">
            <thead>
                <tr>
                    <th>Médico</th>
                    <th>Paciente</th>
                    <th>Fecha</th>
                    <th>Hora Inicio</th>
                    <th>Hora Fin</th>
                    <th>Diagnóstico</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@(item.MedicoNavigation?.Nombre ?? "—")</strong></td>
                        <td>@(item.PacienteNavigation?.Nombre ?? "—")</td>
                        <td>
                            <span class="veris-badge-tipo">@item.FechaConsulta.ToString("dd/MM/yyyy")</span>
                        </td>
                        <td><span class="veris-hora">@item.Hi.ToString("HH:mm")</span></td>
                        <td><span class="veris-hora">@item.Hf.ToString("HH:mm")</span></td>
                        <td>
                            <span class="veris-badge-diagnostico" title="@item.Diagnostico">
                                @item.Diagnostico
                            </span>
                        </td>
                        <td>
                            <div class="veris-actions">
                                @if (!User.IsInRole("SuperAdmin") && !User.IsInRole("Paciente") && (string.IsNullOrWhiteSpace(item.Diagnostico) || item.Diagnostico.Trim().ToLower() == "pendiente"))
                                {
                                    <a asp-action="Atender" asp-route-id="@item.IdStr" class="veris-btn-atender">&#128203; Atender</a>
                                }
                                @if (!User.IsInRole("Paciente") && !User.IsInRole("Medico"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.IdStr" class="veris-btn-edit">&#9998; Editar</a>
                                }
                                <a asp-action="Details" asp-route-id="@item.IdStr" class="veris-btn-details">&#128269; Detalles</a>
                                @if (User.IsInRole("SuperAdmin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.IdStr" class="veris-btn-delete">&#10005; Eliminar</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="veris-table-footer">
        Total: @total consulta@(total != 1 ? "s" : "") registrada@(total != 1 ? "s" : "")
    </div>
</div>
