@model MoldeMVC_Core.Models.Medicos

@{
    ViewData["Title"] = "Eliminar Médico";
}

<h1>Eliminar Médico</h1>
<h3>¿Está seguro que desea eliminar este registro?</h3>

<div>
    <h4>Médico</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>

        <dt class="col-sm-3">Especialidad</dt>
        <dd class="col-sm-9">@(Model.EspecialidadNavigation?.Descripcion ?? Model.EspecialidadId)</dd>

        <dt class="col-sm-3">Foto</dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(Model.Foto))
            {
                <img src="~/medicos/@Model.Foto" alt="Foto del médico" width="120" height="120" style="object-fit: cover;" />
            }
            else
            {
                <span>Sin foto</span>
            }
        </dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.IdStr" method="post">
        <input type="submit" value="Eliminar" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </form>
</div>
