@model MoldeMVC_Core.Models.Medicos

@{
    ViewData["Title"] = "Detalles de Médico";
}

<div class="veris-detail-card">
    <div class="veris-detail-header">
        <div class="veris-form-icon">&#9877;</div>
        <h1>Detalles del Médico</h1>
    </div>

    <div class="veris-detail-foto-top">
        @if (!string.IsNullOrEmpty(Model.foto))
        {
            <img src="~/medicos/@Model.foto" alt="Foto del médico" class="veris-detail-foto-lg" />
        }
        else
        {
            <div class="veris-detail-sin-foto-lg">Sin<br />foto</div>
        }
        <div class="veris-detail-nombre-top">@Model.nombre</div>
    </div>

    <div class="veris-detail-body">
        <div class="veris-detail-row">
            <span class="veris-detail-label">Nombre</span>
            <span class="veris-detail-value">@Html.DisplayFor(m => m.nombre)</span>
        </div>
        <div class="veris-detail-row">
            <span class="veris-detail-label">Especialidad</span>
            <span class="veris-detail-value">
                <span class="veris-badge-tipo">@ViewBag.EspecialidadNombre</span>
            </span>
        </div>
        <div class="veris-detail-row">
            <span class="veris-detail-label">Foto</span>
            <span class="veris-detail-value">@(string.IsNullOrEmpty(Model.foto) ? "Sin foto asignada" : Model.foto)</span>
        </div>
    </div>

    <div class="veris-detail-footer">
        <a asp-action="Edit" asp-route-id="@Model._id" class="veris-btn-edit">&#9998; Editar</a>
        <a asp-action="Index" class="veris-btn-back">&#8592; Volver</a>
    </div>
</div>
