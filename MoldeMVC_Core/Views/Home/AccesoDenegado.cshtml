@using System.Security.Claims
@{
    ViewData["Title"] = "Acceso denegado";
    var roles = User.Claims
        .Where(c => c.Type == ClaimTypes.Role)
        .Select(c => c.Value)
        .ToList();
    var rolTexto = roles.Any() ? string.Join(", ", roles) : "sin rol asignado";
}

<div class="veris-detail-card" style="max-width:600px; margin:60px auto; text-align:center;">
    <div class="veris-detail-header">
        <div class="veris-form-icon" style="font-size:2.5rem;">&#128683;</div>
        <h1 style="color:#c0392b;">Acceso denegado</h1>
    </div>

    <div class="veris-detail-body" style="padding:2rem 1.5rem;">
        <p style="font-size:1.1rem; margin-bottom:0.5rem;">
            No tienes permisos para acceder a este módulo.
        </p>
        <p style="color:#666; font-size:0.95rem;">
            Tu rol actual (<strong>@rolTexto</strong>) no tiene acceso a la sección que intentaste visitar.
        </p>
    </div>

    <div class="veris-detail-footer" style="justify-content:center;">
        <a asp-controller="Home" asp-action="Index" class="veris-btn-back">&#8592; Volver al inicio</a>
    </div>
</div>
