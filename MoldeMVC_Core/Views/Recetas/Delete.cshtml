@model MoldeMVC_Core.Models.Recetas

@{
    ViewData["Title"] = "Eliminar Receta";
}

<h1>Eliminar Receta</h1>
<h3>¿Está seguro que desea eliminar este registro?</h3>

<div>
    <h4>Receta</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Consulta</dt>
        <dd class="col-sm-9">@(Model.ConsultaNavigation != null
            ? $"{Model.ConsultaNavigation.FechaConsulta:dd/MM/yyyy} — {Model.ConsultaNavigation.Hi:HH\\:mm}"
            : Model.ConsultaId)</dd>

        <dt class="col-sm-3">Medicamento</dt>
        <dd class="col-sm-9">@(Model.MedicamentoNavigation?.Nombre ?? Model.MedicamentoId)</dd>

        <dt class="col-sm-3">Cantidad</dt>
        <dd class="col-sm-9">@Model.Cantidad</dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.IdStr" method="post">
        <input type="submit" value="Eliminar" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </form>
</div>
