@model IEnumerable<MoldeMVC_Core.Models.Recetas>

@{
    ViewData["Title"] = "Listado de Recetas";
    var total = Model.Count();
}

<div class="veris-table-card">
    <div class="veris-table-header">
        <h1>Recetas</h1>
        <span class="veris-badge-count">@total registro@(total != 1 ? "s" : "")</span>
    </div>
    <div class="veris-table-toolbar">
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Nueva Receta</a>
    </div>
    <div class="veris-table-wrapper">
        <table class="table veris-table">
            <thead>
                <tr>
                    <th>Consulta</th>
                    <th>Medicamento</th>
                    <th>Cantidad</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @(ViewBag.ConsultasDict != null && ViewBag.ConsultasDict.ContainsKey(item.consultaId)
                                ? ViewBag.ConsultasDict[item.consultaId]
                                : item.consultaId)
                        </td>
                        <td>
                            <span class="veris-badge-tipo">
                                @(ViewBag.MedicamentosDict != null && ViewBag.MedicamentosDict.ContainsKey(item.medicamentoId)
                                    ? ViewBag.MedicamentosDict[item.medicamentoId]
                                    : item.medicamentoId)
                            </span>
                        </td>
                        <td>
                            <strong>@Html.DisplayFor(modelItem => item.cantidad)</strong>
                        </td>
                        <td>
                            <div class="veris-actions">
                                <a asp-action="Edit" asp-route-id="@item._id" class="veris-btn-edit">&#9998; Editar</a>
                                <a asp-action="Details" asp-route-id="@item._id" class="veris-btn-details">&#128269; Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item._id" class="veris-btn-delete">&#10005; Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="veris-table-footer">
        Total: @total receta@(total != 1 ? "s" : "") registrada@(total != 1 ? "s" : "")
    </div>
</div>
