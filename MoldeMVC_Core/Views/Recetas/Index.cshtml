@model IEnumerable<MoldeMVC_Core.Models.Recetas>

@{
    ViewData["Title"] = "Listado de Recetas";
    var total = Model.Count();
}

<div class="veris-table-card">
    <div class="veris-table-header">
        <h1>Recetas</h1>
        <span class="veris-badge-count">@total registro@(total != 1 ? "s" : "")</span>
    </div>
    @if (!User.IsInRole("Paciente"))
    {
        <div class="veris-table-toolbar">
            <a asp-action="Create" class="btn btn-primary btn-sm">+ Nueva Receta</a>
        </div>
    }
    <div class="veris-table-wrapper">
        <table class="table veris-table">
            <thead>
                <tr>
                    <th>Consulta</th>
                    <th>Medicamento</th>
                    <th>Cantidad</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (item.ConsultaNavigation != null)
                            {
                                @($"{item.ConsultaNavigation.FechaConsulta:dd/MM/yyyy} — {item.ConsultaNavigation.Hi:HH\\:mm}–{item.ConsultaNavigation.Hf:HH\\:mm}")
                            }
                            else
                            {
                                @item.ConsultaId
                            }
                        </td>
                        <td>
                            <span class="veris-badge-tipo">
                                @(item.MedicamentoNavigation?.Nombre ?? item.MedicamentoId)
                            </span>
                        </td>
                        <td>
                            <strong>@item.Cantidad</strong>
                        </td>
                        <td>
                            <div class="veris-actions">
                                @if (!User.IsInRole("Paciente"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.IdStr" class="veris-btn-edit">&#9998; Editar</a>
                                }
                                <a asp-action="Details" asp-route-id="@item.IdStr" class="veris-btn-details">&#128269; Detalles</a>
                                @if (!User.IsInRole("Paciente"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.IdStr" class="veris-btn-delete">&#10005; Eliminar</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="veris-table-footer">
        Total: @total receta@(total != 1 ? "s" : "") registrada@(total != 1 ? "s" : "")
    </div>
</div>
