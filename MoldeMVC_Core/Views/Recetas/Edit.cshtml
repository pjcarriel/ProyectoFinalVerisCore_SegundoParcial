@model MoldeMVC_Core.Models.Recetas

@{
    ViewData["Title"] = "Editar Receta";
}

<div class="veris-form-card">
    <div class="veris-form-header">
        <div class="veris-form-icon">&#9998;</div>
        <h1>Editar Receta</h1>
    </div>
    <form asp-action="Edit" asp-route-id="@Model.IdStr" method="post">
        <div class="veris-form-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="veris-form-group">
                <label asp-for="ConsultaId" class="veris-form-label">Consulta</label>
                <select asp-for="ConsultaId" asp-items="ViewBag.Consultas" class="veris-form-control">
                    <option value="">-- Seleccione una consulta --</option>
                </select>
                <span asp-validation-for="ConsultaId" class="veris-form-error"></span>
            </div>

            <div class="veris-form-group">
                <label asp-for="MedicamentoId" class="veris-form-label">Medicamento</label>
                <select asp-for="MedicamentoId" asp-items="ViewBag.Medicamentos" class="veris-form-control">
                    <option value="">-- Seleccione un medicamento --</option>
                </select>
                <span asp-validation-for="MedicamentoId" class="veris-form-error"></span>
            </div>

            <div class="veris-form-group">
                <label asp-for="Cantidad" class="veris-form-label">Cantidad</label>
                <input asp-for="Cantidad" type="number" min="1" class="veris-form-control" />
                <span asp-validation-for="Cantidad" class="veris-form-error"></span>
            </div>
        </div>
        <div class="veris-form-footer">
            <button type="submit" class="veris-btn-submit">&#10003; Guardar Cambios</button>
            <a asp-action="Index" class="veris-btn-back">&#8592; Volver</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
