@page
@model RegisterModel
@{
    ViewData["Title"] = "Registrarse";
}

<style>
    .btn-veris {
        background-color: #4f84ef;
        color: white;
    }
    .btn-veris:hover {
        background-color: #34c9d4;
        color: white;
    }
</style>

<main aria-labelledby="title" class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="row align-items-center shadow rounded-4 overflow-hidden bg-white">

                <!-- FORMULARIO (IZQUIERDA) -->
                <div class="col-md-6 p-4">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <h2 id="title" class="fw-bold" style="color:#4f84ef;">@ViewData["Title"]</h2>
                        <h6 class="text-muted mb-3">Cree una cuenta nueva.</h6>
                        <hr />

                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Input.UserName" class="form-label">Nombre de usuario</label>
                            <input asp-for="Input.UserName" class="form-control" autocomplete="username"
                                   aria-required="true" placeholder="Ingrese su usuario" />
                            <span asp-validation-for="Input.UserName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">Correo electrónico</label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="email"
                                   aria-required="true" placeholder="Ingrese su correo" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">Contraseña</label>
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password"
                                   aria-required="true" placeholder="Ingrese su contraseña" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.ConfirmPassword" class="form-label">Confirmar contraseña</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password"
                                   aria-required="true" placeholder="Confirme su contraseña" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <button id="registerSubmit" type="submit" class="btn btn-veris px-4">
                                Registrarse
                            </button>
                        </div>
                    </form>
                </div>

                <!-- IMAGEN (DERECHA) -->
                <div class="col-md-6 d-flex justify-content-center align-items-center p-4">
                    <div class="text-center text-white rounded-4 shadow p-4"
                         style="max-width:380px; background:linear-gradient(135deg,#4f83f1,#2cc8c8);">

                        <h3 class="mb-3">Bienvenido a VERIS</h3>

                        <img src="~/Imagenes/RegistroVeris.jpeg"
                             alt="Registro VERIS"
                             class="img-fluid rounded-4 shadow mb-3"
                             style="width:180px; height:240px; object-fit:cover; border:6px solid white;" />

                        <p class="mb-0">
                            Regístrate para agendar citas médicas y acceder a nuestros servicios de salud.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
